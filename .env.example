# Gateway
DROST_GATEWAY_HOST=0.0.0.0
DROST_GATEWAY_PORT=8766
DROST_LOG_LEVEL=INFO

# Telegram (required)
DROST_TELEGRAM_BOT_TOKEN=
DROST_TELEGRAM_ALLOWED_USER_IDS=

# Telegram webhook mode (optional; polling is used when URL is empty)
DROST_TELEGRAM_WEBHOOK_URL=
DROST_TELEGRAM_WEBHOOK_PATH=/webhook/telegram
DROST_TELEGRAM_WEBHOOK_SECRET=

# Provider routing
# openai-codex | anthropic | xai
DROST_DEFAULT_PROVIDER=openai-codex

# OpenAI / Codex
DROST_OPENAI_MODEL=gpt-5.3-codex
DROST_OPENAI_API_KEY=
DROST_OPENAI_BASE_URL=
DROST_OPENAI_CODEX_AUTH_PATH=~/.codex/auth.json

# Anthropic (API key or setup-token like sk-ant-oat...)
DROST_ANTHROPIC_MODEL=claude-sonnet-4-6
DROST_ANTHROPIC_TOKEN=

# xAI via OpenAI-compatible Responses API
DROST_XAI_MODEL=grok-4.1-fast-reasoning
DROST_XAI_API_KEY=
DROST_XAI_BASE_URL=https://api.x.ai/v1

# Web search (Exa)
EXA_API_KEY=

# SQLite + vector memory
DROST_SQLITE_PATH=~/.drost/drost.sqlite3
# optional explicit extension path (.dylib/.so/.dll)
DROST_SQVECTOR_EXTENSION_PATH=
DROST_MEMORY_ENABLED=true
DROST_MEMORY_TOP_K=6
DROST_MEMORY_EMBEDDING_PROVIDER=openai
DROST_MEMORY_EMBEDDING_MODEL=text-embedding-3-small
DROST_MEMORY_EMBEDDING_DIMENSIONS=384

# Session/history
DROST_SESSION_HISTORY_LIMIT=64
