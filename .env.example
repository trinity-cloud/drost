# Core runtime
DROST_APP_NAME=drost
DROST_LOG_LEVEL=INFO
DROST_GATEWAY_HOST=0.0.0.0
DROST_GATEWAY_PORT=8766
# Optional explicit health URL override. Leave blank to derive from host + port.
DROST_GATEWAY_HEALTH_URL=

# Runtime topology
# Leave DROST_REPO_ROOT unset unless you need to override the repo root explicitly.
# DROST_REPO_ROOT=/absolute/path/to/drost
DROST_RUNTIME_LAUNCH_MODE=deployer-default
DROST_RUNTIME_START_COMMAND=uv run drost

# Workspace, traces, attachments
DROST_WORKSPACE_DIR=~/.drost
DROST_ATTACHMENTS_DIR=~/.drost/attachments
DROST_TRACE_ENABLED=true
DROST_TRACE_DIR=~/.drost/traces
DROST_PROMPT_WORKSPACE_FILES=SOUL.md,IDENTITY.md,USER.md,MEMORY.md

# Telegram
DROST_TELEGRAM_BOT_TOKEN=
DROST_TELEGRAM_ALLOWED_USER_IDS=

# Telegram webhook mode (polling is used when URL is empty)
DROST_TELEGRAM_WEBHOOK_URL=
DROST_TELEGRAM_WEBHOOK_PATH=/webhook/telegram
DROST_TELEGRAM_WEBHOOK_SECRET=

# Provider routing
# openai-codex | anthropic | xai
DROST_DEFAULT_PROVIDER=openai-codex

# OpenAI / Codex
# Leave DROST_OPENAI_API_KEY blank to use Codex OAuth from auth.json.
DROST_OPENAI_MODEL=gpt-5-codex
DROST_OPENAI_API_KEY=
DROST_OPENAI_BASE_URL=
DROST_OPENAI_CODEX_AUTH_PATH=~/.codex/auth.json

# Anthropic
DROST_ANTHROPIC_MODEL=claude-sonnet-4-20250514
DROST_ANTHROPIC_TOKEN=

# xAI via OpenAI-compatible Responses API
DROST_XAI_MODEL=grok-3-latest
DROST_XAI_API_KEY=
DROST_XAI_BASE_URL=https://api.x.ai/v1

# Search + embeddings
# These are the canonical env vars Drost reads from .env.
EXA_API_KEY=
GEMINI_API_KEY=
# Compatibility aliases, if you prefer the DROST_-prefixed names:
# DROST_EXA_API_KEY=
# DROST_GEMINI_API_KEY=

# SQLite + vector memory
DROST_SQLITE_PATH=~/.drost/drost.sqlite3
# Optional explicit sqlite-vec extension path (.dylib/.so/.dll)
DROST_SQVECTOR_EXTENSION_PATH=
DROST_MEMORY_ENABLED=true
DROST_MEMORY_TOP_K=6
DROST_MEMORY_EMBEDDING_PROVIDER=gemini
DROST_MEMORY_EMBEDDING_MODEL=gemini-embedding-001
DROST_MEMORY_EMBEDDING_DIMENSIONS=3072

# Memory maintenance and synthesis
DROST_MEMORY_MAINTENANCE_ENABLED=true
DROST_MEMORY_MAINTENANCE_INTERVAL_SECONDS=1800
DROST_MEMORY_MAINTENANCE_MAX_EVENTS_PER_RUN=200
DROST_MEMORY_ENTITY_SYNTHESIS_ENABLED=true

# Session continuity and prompt-time memory capsule
DROST_MEMORY_CONTINUITY_ENABLED=true
DROST_MEMORY_CONTINUITY_AUTO_ON_NEW=true
DROST_MEMORY_CONTINUITY_SOURCE_MAX_MESSAGES=120
DROST_MEMORY_CONTINUITY_SOURCE_MAX_CHARS=40000
DROST_MEMORY_CONTINUITY_SUMMARY_MAX_TOKENS=1500
DROST_MEMORY_CONTINUITY_SUMMARY_MAX_CHARS=12000
DROST_MEMORY_CONTINUITY_INJECT_UNTIL_MESSAGES=12
DROST_MEMORY_CAPSULE_ENABLED=true
DROST_MEMORY_CAPSULE_SEARCH_LIMIT=18

# Follow-ups, idle mode, and proactive surfacing
DROST_FOLLOWUPS_ENABLED=true
DROST_FOLLOWUP_CONFIDENCE_THRESHOLD=0.8
DROST_FOLLOWUP_PROMPT_LOOKAHEAD_HOURS=72
DROST_IDLE_MODE_ENABLED=true
DROST_IDLE_ACTIVE_WINDOW_SECONDS=1200
DROST_IDLE_HEARTBEAT_ENABLED=true
DROST_IDLE_HEARTBEAT_INTERVAL_SECONDS=1800
DROST_PROACTIVE_SURFACING_ENABLED=true
DROST_PROACTIVE_FOLLOWUP_COOLDOWN_SECONDS=21600

# Session history and agent loop
DROST_SESSION_HISTORY_LIMIT=64
# Recommended interactive tuning for real agent work.
DROST_AGENT_MAX_TOOL_CALLS_PER_RUN=100
DROST_AGENT_MAX_ITERATIONS=100
DROST_AGENT_TOOL_TIMEOUT_SECONDS=30.0
DROST_AGENT_RUN_TIMEOUT_SECONDS=180.0

# Context budgets
DROST_CONTEXT_BUDGET_TOTAL_TOKENS=96000
DROST_CONTEXT_BUDGET_SYSTEM_TOKENS=24000
DROST_CONTEXT_BUDGET_HISTORY_TOKENS=24000
DROST_CONTEXT_BUDGET_MEMORY_TOKENS=24000
DROST_CONTEXT_BUDGET_RESERVE_TOKENS=24000

# History compaction
DROST_HISTORY_COMPACTION_ENABLED=true
DROST_HISTORY_COMPACTION_TRIGGER_RATIO=0.7
DROST_HISTORY_COMPACTION_KEEP_RECENT_MESSAGES=12
DROST_HISTORY_COMPACTION_SUMMARY_MAX_TOKENS=1500

# Vision
DROST_VISION_MAX_INLINE_IMAGE_BYTES=5242880

# Deployer advanced overrides
# Leave these unset unless you need to override the default supervised mode.
# DROST_DEPLOYER_START_COMMAND=uv run drost-gateway
# DROST_DEPLOYER_HEALTH_URL=http://127.0.0.1:8766/health
# DROST_DEPLOYER_STARTUP_GRACE_SECONDS=2.0
# DROST_DEPLOYER_HEALTH_TIMEOUT_SECONDS=20.0
# DROST_DEPLOYER_REQUEST_POLL_INTERVAL_SECONDS=1.0
# DROST_DEPLOYER_KNOWN_GOOD_REF_NAME=drost-known-good

# Optional fallback env vars accepted by provider adapters
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
